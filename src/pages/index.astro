---
import Layout from '../layouts/Layout.astro';

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "World Cup 2026 Hub",
  "url": "https://fifaworld-cup-2026.org", 
  "description": "The ultimate fast, data-driven guide for the FIFA World Cup 2026.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://fifaworld-cup-2026.org/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<Layout 
  title="FIFA World Cup 2026: Ultimate Guide, Tickets & Standings" 
  description="Your lightning-fast portal for the 2026 World Cup in USA, Mexico, and Canada. Live CONMEBOL standings, ticket alerts, and complete group stages."
  schema={websiteSchema} 
>
  <section class="text-center py-12 md:py-20 mb-8 border-b border-gray-200">
    <h1 class="text-5xl md:text-7xl font-extrabold text-blue-900 tracking-tight mb-6">
      Destination: <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-red-600">North America 2026</span>
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
      The largest tournament in football history. 48 teams. 3 nations. One lightning-fast hub for everything you need to know, without the clutter.
    </p>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
    
    <a href="/fifa-world-cup-2026-tickets" class="group block p-6 bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:border-blue-200 transition-all duration-300">
      <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-600 transition-colors">
        <svg class="w-6 h-6 text-blue-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path></svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Ticket Alerts</h2>
      <p class="text-gray-600">Don't miss the next sales phase. Get official information and secure your spot.</p>
    </a>

    <a href="/fifa-world-cup-2026-groups" class="group block p-6 bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:border-blue-200 transition-all duration-300">
      <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-600 transition-colors">
        <svg class="w-6 h-6 text-blue-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Group Stages</h2>
      <p class="text-gray-600">Explore the historic 48-team format. Complete draw analysis and key matchups.</p>
    </a>

    <a href="/fifa-world-cup-2026-qualification-conmebol-standings" class="group block p-6 bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:border-blue-200 transition-all duration-300">
      <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4 group-hover:bg-blue-600 transition-colors">
        <svg class="w-6 h-6 text-blue-600 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"></path></svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">CONMEBOL Qualifiers</h2>
      <p class="text-gray-600">The most grueling path to the World Cup. Check the definitive standings.</p>
    </a>

  </section>
</Layout>